Design code
module earbud_controller(
    input clk,
    input power_btn,
    input touch,
    input charge_connected,
    input in_ear,
    input [7:0] battery_level,

    output reg led,
    output reg music,
    output reg charging,
    output reg low_battery
);

always @(posedge clk)
begin

    // Power ON/OFF
    if(power_btn)
        led <= ~led;

    // Play/Pause
    if(touch && in_ear)
        music <= ~music;

    // Charging Status
    if(charge_connected)
        charging <= 1;
    else
        charging <= 0;

    // Low Battery Detection
    if(battery_level < 8'd20)
        low_battery <= 1;
    else
        low_battery <= 0;

end

endmodule

